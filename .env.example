# Environment Configuration
ENVIRONMENT=development
HOST=0.0.0.0
PORT=10000

# Security
API_KEY=your-secure-api-key-here

# Database
DATABASE_URL=sqlite:///health_reports.db

# Logging
LOG_LEVEL=INFO

# Application
APP_NAME=INBLOODO AGENT
APP_VERSION=2.0.0

# Multi-LLM Configuration
# Specify primary LLM provider: gemini (default), openai, or claude
# System will automatically fallback to other available LLMs if primary fails
LLM_PROVIDER=gemini

# Google Gemini API Key (for gemini provider)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (for openai provider)
# Uncomment and add your key to enable OpenAI GPT
# OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude API Key (for claude provider)
# Uncomment and add your key to enable Claude
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key